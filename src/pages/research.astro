---
import Layout from "@/layouts/Layout.astro";
import { profile, researchPage } from "@/settings";
import BetterIcon from "@/components/ui/BetterIcon.astro";
import List from "@/components/ui/List.astro";
import {RESEARCH_ICONS} from "@/data/researchIcons";

const { research_areas } = profile;
const { highlight } = researchPage;
---

<Layout title="Research | Dr. Chia-Yu Yang" description="Research statement and areas of interest for Dr. Chia-Yu Yang, focusing on soil genesis, environmental geochemistry, and climate science.">
    <div class='mx-auto w-full max-w-3xl px-6 lg:max-w-4xl lg:px-0'></div>
    <h1 class="text-3xl font-bold mb-8">Research Statement</h1>
<div class="mb-12">
  <p class="text-lg mb-6 text-justify">
    I study soils as dynamic systems linking minerals, ecosystems, and climate. 
    My research focuses on how mineral weathering and pedogenic processes control elemental cycling, soil fertility, and environmental responses across agricultural and natural systems.
  </p>
  <p class="text-lg mb-6 text-justify">
    Integrating mineralogy (XRPD), geochemistry, and field-based observations, I aim to provide direct evidence of soil processes and connect mineral-scale transformations to global environmental change, including enhanced rock weathering (ERW) as a climate mitigation strategy.
  </p>
</div>
    </div>

   <!-- Highlight + Field Site 合併 -->
<section class="mb-16 grid gap-8 lg:grid-cols-12 items-start">
  <div class="space-y-4 lg:col-span-5">
    <p class="text-sm font-semibold uppercase tracking-[0.08em] text-accent">Featured Research</p>
    <h2 class="text-2xl font-bold text-base-content">{highlight.title}</h2>
    <p class="text-base text-base-content/80 leading-relaxed">
      Field-based investigation of enhanced rock weathering (ERW) in paddy soils, focusing on mineral transformation, soil chemical dynamics, and greenhouse gas responses under real agricultural conditions.
    </p>

    <p class="text-base text-base-content/70 leading-relaxed">
      Field site: Yosano Town, Kyoto — replicated basalt-amended and control plots used to quantify weathering processes and biogeochemical responses.
    </p>
  </div>

  <div class="lg:col-span-7 space-y-4">
    <div class="w-full rounded-2xl overflow-hidden shadow-xl border border-base-300 bg-base-200">
      <div class="aspect-video bg-base-100">
        <video
          controls
          poster={highlight.poster}
          class="w-full h-full object-cover"
        >
          <source src={highlight.videoSrc} type="video/mp4" />
        </video>
      </div>
    </div>

    <img 
      src="/images/field/paddy-erw-site.png" 
      alt="Paddy field ERW experimental plots" 
      class="rounded-lg shadow-md"
    />
  </div>
</section>

<!-- Selected Projects（簡化） -->
<List listTitle="Current Works" listItems={[
  {
    title: "Enhanced Rock Weathering",
    description: "Field validation of mineral weathering and its role in climate mitigation and soil processes."
  },
  {
    title: "Ultramafic Soil Systems",
    description: "Pedogenesis and metal (Cr, Ni) redistribution across climatic gradients."
  },
  {
    title: "Soil–Environment Interface",
    description: "Linking mineralogy and geochemistry to environmental risk and agricultural systems."
  }
]} />

<!-- Research Themes（取代 Areas + Impact） -->
<h2 class="text-2xl font-bold mb-6">Research Themes</h2>

<div class="grid gap-8 mb-12">
  {
    research_areas.map((area) => (
      <div class="flex gap-6 items-start">
        <BetterIcon>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            class="size-6 stroke-accent"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d={RESEARCH_ICONS[area.field as keyof typeof RESEARCH_ICONS]?.path || RESEARCH_ICONS['soil chemistry'].path}
            />
          </svg>
        </BetterIcon>

        <div>
          <h3 class="text-xl font-semibold mb-2">{area.title}</h3>
          <p class="text-base text-justify">{area.description}</p>
        </div>
      </div>
    ))
  }
</div>
</Layout>
